<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vroom Vroom Clicker</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: linear-gradient(180deg,#0f1724 0%, #1a1a2e 60%); color: #eee; min-height: 100vh; }

      /* Garage theme */
      .garage { background-image: radial-gradient(rgba(255,255,255,0.015) 1px, transparent 1px);
            background-size: 6px 6px; padding-bottom: 3rem; }
      .garage-header { display:flex; align-items:center; gap:1rem; padding:1.2rem; background: linear-gradient(90deg,#0b1220,#16213e); border-bottom: 4px solid #0f3460; }
      .garage-logo { font-weight: 800; color:#ffcc00; font-size:1.4rem; letter-spacing:1px; text-shadow: 0 2px 0 rgba(0,0,0,.6); }
      .garage-sign { background:#0f3460; color:#fff; padding:.35rem .6rem; border-radius:4px; border:1px solid #06203a; }
      .workbench { background: linear-gradient(180deg,#0d1320, #071021); border: 1px solid rgba(255,255,255,0.03); padding: .8rem; border-radius:8px; box-shadow: 0 8px 30px rgba(2,6,23,.6); }

      /* HUD */
      .hud { display: flex; align-items: center; gap: 1.5rem; background: #16213e; padding: .8rem 1.5rem; flex-wrap: wrap; }
      .hud-item { display: flex; flex-direction: column; align-items: center; }
      .hud-label { font-size: .7rem; color: #aaa; text-transform: uppercase; }
      .hud-value { font-size: 1.4rem; font-weight: bold; color: #e94560; }
      .logout-btn { background: none; border: 1px solid #e94560; color: #e94560; padding: .3rem .8rem; border-radius: 4px; cursor: pointer; font-size: .85rem; margin-left: auto; }
      .logout-btn:hover { background: #e94560; color: #fff; }

      /* Zone principale */
      .game-container { display: flex; gap: 1rem; padding: 1rem; max-width: 1200px; margin: 0 auto; }
      .game-left { flex: 0 0 320px; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
      .game-right { flex: 1; }

      /* Bouton clic */
      .click-btn {
        width: 200px; height: 200px; border-radius: 50%;
        background: radial-gradient(circle, #e94560, #c73652);
        border: 4px solid #ff6b6b; cursor: pointer; font-size: 3rem;
        transition: transform .1s, box-shadow .1s;
        box-shadow: 0 0 20px rgba(233,69,96,.5);
        display: flex; align-items: center; justify-content: center;
      }
      .click-btn:active { transform: scale(.95); box-shadow: 0 0 10px rgba(233,69,96,.3); }

      /* Événements */
      .events-container { margin-bottom: 1rem; width: 100%; }
      .event-banner {
        display: flex; align-items: center; gap: .8rem;
        padding: .7rem 1.2rem; border-radius: 6px; margin-bottom: .5rem;
      }
      .event-bonus { background: #1a472a; border-left: 4px solid #2ecc71; }
      .event-malus { background: #4a1a1a; border-left: 4px solid #e94560; }
      .event-icon { font-size: 1.3rem; }
      .event-label { font-weight: bold; flex: 1; }
      .event-countdown { font-size: .85rem; color: #aaa; }
      .event-resolve-btn {
        background: #e94560; color: #fff; border: none;
        padding: .4rem .9rem; border-radius: 4px; cursor: pointer; font-size: .85rem;
      }
      .event-resolve-btn:hover { background: #c73652; }

      /* Upgrades */
      .upgrades-panel h2 { margin-bottom: .8rem; color: #e94560; }
      .upgrade-category { margin-bottom: 1.5rem; }
      .upgrade-category h3 { margin-bottom: .5rem; font-size: .95rem; color: #aaa; border-bottom: 1px solid #333; padding-bottom: .3rem; }
      .upgrade-list { display: flex; flex-direction: column; gap: .4rem; }
      .upgrade-item { display: flex; align-items: center; gap: .5rem; background: #16213e; padding: .5rem .8rem; border-radius: 5px; }
      .upgrade-item.owned { opacity: .6; }
      .upgrade-name { flex: 1; font-size: .9rem; }
      .upgrade-cost { font-size: .8rem; color: #aaa; }
      .upgrade-btn {
        background: #0f3460; border: 1px solid #e94560; color: #eee;
        padding: .3rem .7rem; border-radius: 4px; cursor: pointer; font-size: .8rem;
      }
      .upgrade-btn:disabled { opacity: .4; cursor: not-allowed; }
      .upgrade-btn:not(:disabled):hover { background: #e94560; }
      .upgrade-owned-mark { font-size: 1rem; }
    </style>
  </head>
  <body>
    <div class="garage">
      <header class="garage-header">
        <div class="garage-logo">GARAGE VROOM</div>
        <div class="garage-sign">Open • Tune • Race</div>
        <div style="margin-left:auto;color:#9fb0d3">Welcome, <%= state?.userId ?? 'guest' %></div>
      </header>

      <div class="game-container">
      <div class="game-left">
        <%- include('partials/events', { state }) %>
        <button
          class="click-btn"
          data-testid="click-button"
          id="click-button"
          onclick="handleClick()"
          aria-label="Cliquer pour gagner des chevaux"
        >🏎️</button>
      </div>
      <div class="game-right">
        <%- include('partials/upgrades', { state, catalog }) %>
      </div>
    </div>

    </div>

    <script>
      let clientState = <%- JSON.stringify(state) %>;

      function fmt(n) {
        if (n >= 1e9) return Math.floor(n / 1e9) + 'MM';
        if (n >= 1e6) return Math.floor(n / 1e6) + 'M';
        if (n >= 1e3) return Math.floor(n / 1e3) + 'K';
        return String(Math.floor(n));
      }

      function updateHUD(newState) {
        clientState = { ...clientState, ...newState };
        document.getElementById('horse-count-display').textContent = fmt(clientState.horses);
        document.getElementById('click-power-display').textContent = clientState.clickPower;
        if (clientState.engineDisplay) {
          const ed = document.getElementById('engine-display');
          ed.textContent = clientState.engineDisplay;
          ed.parentElement.style.display = '';
        }
      }

      async function handleClick() {
        // Bloquer si POLICE_CONTROL actif
        if (clientState.activeEvent && clientState.activeEvent.type === 'POLICE_CONTROL') return;
        try {
          const resp = await fetch('/game/click', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          if (!resp.ok) return;
          const data = await resp.json();
          updateHUD(data);
        } catch (e) { /* réseau */ }
      }

      async function buyUpgrade(categoryId, tierId) {
        try {
          const resp = await fetch('/game/upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ categoryId, tierId }),
          });
          if (!resp.ok) return;
          window.location.reload();
        } catch (e) { /* réseau */ }
      }

      async function resolveEvent() {
        try {
          const resp = await fetch('/game/event/resolve', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          if (!resp.ok) return;
          clientState.activeEvent = null;
          document.getElementById('events-container').innerHTML = '';
        } catch (e) { /* réseau */ }
      }

      // Compte à rebours événement
      function startCountdown() {
        const el = document.getElementById('event-countdown');
        const banner = document.querySelector('[data-testid="event-banner"]');
        if (!el || !banner) return;
        const expiresAt = parseInt(banner.dataset.expiresAt, 10);
        if (!expiresAt) return;

        const tick = () => {
          const remaining = Math.max(0, Math.ceil((expiresAt - Date.now()) / 1000));
          el.textContent = remaining + 's';
          if (remaining <= 0) {
            banner.remove();
            clearInterval(timer);
            clientState.activeEvent = null;
          }
        };
        tick();
        const timer = setInterval(tick, 500);
      }
      startCountdown();

      // Tick passif toutes les secondes
      setInterval(async () => {
        try {
          const resp = await fetch('/game/tick', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ now: Date.now() }),
          });
          if (!resp.ok) return;
          const data = await resp.json();
          updateHUD(data);
        } catch (e) { /* réseau */ }
      }, 1000);
    </script>
  </body>
</html>
