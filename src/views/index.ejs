<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vroom Vroom Clicker</title>
    <link rel="stylesheet" href="/garage.css" />
</head>

<body>
    <div class="app-shell">
        <div class="page-frame">
            <%- include('partials/hud', { state, formatHorses }) %>

                <main class="garage-layout">
                    <section class="game-stage">
                        <%- include('partials/events', { state }) %>
                            <button class="click-btn" data-testid="click-button" id="click-button"
                                onclick="handleClick()" aria-label="Cliquer pour gagner des chevaux">🏎️</button>
                    </section>

                    <section class="garage-panel">
                        <%- include('partials/upgrades', { state, catalog, permanentUpgrades }) %>
                    </section>
                </main>
        </div>
    </div>

    <script>
        let clientState = <%- JSON.stringify(state) %>;
        const upgradeCatalog = <%- JSON.stringify(catalog) %>;
        const permanentUpgradeCatalog = <%- JSON.stringify(permanentUpgrades) %>;

        function fmt(value) {
            if (value >= 1e9) return `${Math.floor(value / 1e9)}MM`;
            if (value >= 1e6) return `${Math.floor(value / 1e6)}M`;
            if (value >= 1e3) return `${Math.floor(value / 1e3)}K`;
            return `${Math.floor(value)}`;
        }

        function getOwnedTierMap(state) {
            const map = {};
            for (const upgrade of state.upgrades ?? []) {
                const current = map[upgrade.categoryId];
                if (!current || Number(upgrade.tierId) > Number(current.tierId)) {
                    map[upgrade.categoryId] = upgrade;
                }
            }
            return map;
        }

        function getOwnedPermanentSet(state) {
            return new Set((state.permanentUpgrades ?? []).map((entry) => entry.upgradeId));
        }

        function getSortedTiers(categoryId) {
            return Object.entries(upgradeCatalog[categoryId].tiers)
                .map(([tierId, tier]) => ({ tierId: Number(tierId), ...tier }))
                .sort((left, right) => left.tierId - right.tierId);
        }

        function getCurrentTierInfo(categoryId, ownedMap) {
            const category = upgradeCatalog[categoryId];
            const ownedUpgrade = ownedMap[categoryId];
            const sortedTiers = getSortedTiers(categoryId);
            const currentTierId = ownedUpgrade ? Number(ownedUpgrade.tierId) : sortedTiers[0].tierId;
            const currentTier = category.tiers[currentTierId] ?? sortedTiers[0];
            const nextTier = sortedTiers.find((entry) => entry.tierId > currentTierId) ?? null;
            return { currentTierId, currentTier, nextTier };
        }

        function updateHUD(newState) {
            clientState = { ...clientState, ...newState };

            const horsesDisplay = document.getElementById('horse-count-display');
            const totalEarnedDisplay = document.getElementById('total-earned-display');
            const clickPowerDisplay = document.getElementById('click-power-display');
            const passiveCpsDisplay = document.getElementById('passive-cps-display');
            const upgradeCountDisplay = document.getElementById('upgrade-count-display');
            const engineDisplay = document.getElementById('engine-display');

            if (horsesDisplay) horsesDisplay.textContent = fmt(clientState.horses ?? 0);
            if (totalEarnedDisplay) totalEarnedDisplay.textContent = fmt(clientState.totalHorsesEarned ?? 0);
            if (clickPowerDisplay) clickPowerDisplay.textContent = `${clientState.clickPower ?? 1}`;
            if (passiveCpsDisplay) passiveCpsDisplay.textContent = `${clientState.cps ?? 0}`;
            if (upgradeCountDisplay) {
                const count = (clientState.upgrades ?? []).length + (clientState.permanentUpgrades ?? []).length;
                upgradeCountDisplay.textContent = `${count}`;
            }
            if (engineDisplay) {
                const engineValue = clientState.engineDisplay ?? '—';
                engineDisplay.textContent = engineValue;
                engineDisplay.closest('.hud-card')?.classList.toggle('is-hidden', !clientState.engineDisplay);
            }
        }

        function refreshUpgradeSummaryCards() {
            const ownedMap = getOwnedTierMap(clientState);
            const ownedPermanent = getOwnedPermanentSet(clientState);

            document.querySelectorAll('[data-upgrade-category]').forEach((card) => {
                const categoryId = card.dataset.upgradeCategory;
                const { currentTierId, currentTier, nextTier } = getCurrentTierInfo(categoryId, ownedMap);
                const image = card.querySelector('[data-current-upgrade-image]');
                const label = card.querySelector('[data-current-upgrade-label]');
                const tierBadge = card.querySelector('[data-current-upgrade-tier]');
                const description = card.querySelector('[data-current-upgrade-description]');
                const nextName = card.querySelector('[data-next-upgrade-name]');
                const nextCost = card.querySelector('[data-next-upgrade-cost]');

                if (image) {
                    image.src = `/upgrades/${categoryId}/tier-${currentTierId}.svg`;
                    image.onerror = function onError() {
                        this.onerror = null;
                        this.src = '/upgrades/placeholder.svg';
                    };
                }

                if (label) label.textContent = currentTier?.display ?? 'Palier inconnu';
                if (tierBadge) tierBadge.textContent = `Niv. ${currentTierId}`;
                if (description) {
                    description.textContent = nextTier
                        ? `Prochain visuel : ${nextTier.display}`
                        : 'Dernier palier atteint pour cette catégorie.';
                }
                if (nextName) nextName.textContent = nextTier ? nextTier.display : 'Maximum atteint';
                if (nextCost) nextCost.textContent = nextTier ? `${fmt(nextTier.cost)} 🐴` : '—';
            });

            document.querySelectorAll('[data-tier-button]').forEach((button) => {
                const categoryId = button.dataset.category;
                const tierId = Number(button.dataset.tier);
                const tierDefinition = upgradeCatalog[categoryId].tiers[tierId];
                const owned = (clientState.upgrades ?? []).some(
                    (entry) => entry.categoryId === categoryId && Number(entry.tierId) === tierId,
                );
                const highestOwned = getOwnedTierMap(clientState)[categoryId];
                const nextRequiredTier = highestOwned
                    ? getSortedTiers(categoryId).find((entry) => entry.tierId > Number(highestOwned.tierId))?.tierId
                    : getSortedTiers(categoryId)[0].tierId;
                const isLocked = !owned && tierId !== nextRequiredTier;
                const canAfford = (clientState.horses ?? 0) >= tierDefinition.cost;

                button.disabled = owned || isLocked || !canAfford;
                button.textContent = owned
                    ? 'Installé'
                    : isLocked
                        ? 'Verrouillé'
                        : `Installer · ${fmt(tierDefinition.cost)} 🐴`;
                button.closest('.tier-row')?.classList.toggle('is-owned', owned);
            });

            document.querySelectorAll('[data-permanent-button]').forEach((button) => {
                const upgradeId = button.dataset.upgradeId;
                const upgradeDefinition = permanentUpgradeCatalog.find((entry) => entry.upgradeId === upgradeId);
                const owned = ownedPermanent.has(upgradeId);
                const canAfford = upgradeDefinition ? (clientState.horses ?? 0) >= upgradeDefinition.cost : false;

                button.disabled = owned || !canAfford;
                button.textContent = owned
                    ? 'Installé'
                    : `Installer · ${fmt(upgradeDefinition?.cost ?? 0)} 🐴`;
                button.closest('.permanent-card')?.classList.toggle('owned', owned);
            });
        }

        function updateState(nextState) {
            clientState = { ...clientState, ...nextState };
            updateHUD(clientState);
            refreshUpgradeSummaryCards();
        }

        async function handleClick() {
            if (clientState.activeEvent && clientState.activeEvent.type === 'POLICE_CONTROL') return;
            try {
                const response = await fetch('/game/click', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                if (!response.ok) return;
                updateState(await response.json());
            } catch (error) {
                // réseau
            }
        }

        async function buyUpgrade(categoryId, tierId) {
            try {
                const response = await fetch('/game/upgrade', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ categoryId, tierId }),
                });
                if (!response.ok) return;
                updateState(await response.json());
            } catch (error) {
                // réseau
            }
        }

        async function buyPermanentUpgrade(upgradeId) {
            try {
                const response = await fetch('/game/permanent-upgrade', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ upgradeId }),
                });
                if (!response.ok) return;
                updateState(await response.json());
            } catch (error) {
                // réseau
            }
        }

        async function resolveEvent() {
            try {
                const response = await fetch('/game/event/resolve', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                if (!response.ok) return;
                updateState(await response.json());
                const container = document.getElementById('events-container');
                if (container) container.innerHTML = '';
            } catch (error) {
                // réseau
            }
        }

        function startCountdown() {
            const el = document.getElementById('event-countdown');
            const banner = document.querySelector('[data-testid="event-banner"]');
            if (!el || !banner) return;
            const expiresAt = Number.parseInt(banner.dataset.expiresAt, 10);
            if (!expiresAt) return;

            const tick = () => {
                const remaining = Math.max(0, Math.ceil((expiresAt - Date.now()) / 1000));
                el.textContent = `${remaining}s`;
                if (remaining <= 0) {
                    banner.remove();
                    clearInterval(timer);
                    clientState.activeEvent = null;
                }
            };

            tick();
            const timer = setInterval(tick, 500);
        }

        updateHUD(clientState);
        refreshUpgradeSummaryCards();
        startCountdown();

        setInterval(async () => {
            try {
                const response = await fetch('/game/tick', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ now: Date.now() }),
                });
                if (!response.ok) return;
                updateState(await response.json());
            } catch (error) {
                // réseau
            }
        }, 1000);
    </script>
</body>

</html>